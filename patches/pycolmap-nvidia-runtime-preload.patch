+def _cuda_package_library(module_name: str, pattern: str):
+    """Resolve one required native library from an NVIDIA Python package."""
+    for library_dir in _cuda_package_library_dirs(module_name):
+        if library := next(iter(sorted(library_dir.glob(pattern))), None):
+            return library
+    raise RuntimeError(
+        f"NVIDIA runtime package {module_name} has no library matching {pattern}"
+    )
