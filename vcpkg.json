{
    "name":  "gpu-pycolmap-wheel-builder",
    "version":  "0.1.0",
    "description":  "Native dependencies for the maintained CUDA pycolmap wheels",
    "dependencies":  [
                         "eigen3",
                         "boost-program-options",
                         "boost-graph",
                         "boost-system",
                         "boost-filesystem",
                         "boost-serialization",
                         "freeimage",
                         "openimageio",
                         "glog",
                         "gflags",
                         {
                             "name": "curl",
                             "features": ["sspi"],
                             "platform": "windows"
                         },
                         {
                             "name": "curl",
                             "features": ["openssl"],
                             "platform": "!windows"
                         },
                         "openssl",
                         "sqlite3",
                         "glew",
                         "cgal",
                         "flann",
                         "gklib",
                         "metis",
                         "blas",
                         "lapack",
                         {
                             "name": "suitesparse",
                             "features": ["gpl"]
                         }
                     ],
    "features":  {
                     "cuda":  {
                                  "description":  "Enable CUDA GPU support",
                                  "dependencies":  [
                                                       {
                                                           "name":  "cuda",
                                                           "platform":  "windows | linux"
                                                       }
                                                   ]
                              }
                 },
    "builtin-baseline":  "c59b04f668d20c7dd83f478835e8266a3cc51270"
}
